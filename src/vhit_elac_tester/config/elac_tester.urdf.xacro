<?xml version="1.0"?>
<robot name="elac_tester" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:arg name="hardware" default="real"/>
  <xacro:arg name="dl_node" default="ELAC_node_LAN9253"/>
  <xacro:arg name="initial_position" default="0.0"/>
  <xacro:property name="selected_hardware" value="$(arg hardware)"/>

  <link name="base_link"/>

  <link name="elac_link">
    <inertial>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.05 0.10"/>
      </geometry>
      <material name="elac_blue">
        <color rgba="0.0 0.25 0.8 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.05 0.10"/>
      </geometry>
    </collision>
  </link>

  <joint name="elac_node" type="revolute">
    <parent link="base_link"/>
    <child link="elac_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14159" upper="3.14159" effort="10.0" velocity="1.0"/>
  </joint>

  <ros2_control name="ElacTesterSystem" type="system">
    <xacro:if value="${selected_hardware == 'mock'}">
      <hardware>
        <plugin>mock_components/GenericSystem</plugin>
      </hardware>
    </xacro:if>

    <xacro:if value="${selected_hardware == 'real'}">
      <hardware>
        <plugin>vhit_robot_driver/VhitRobotHardwareInterface</plugin>
      </hardware>
    </xacro:if>

    <joint name="elac_node">
      <param name="DL_node">$(arg dl_node)</param>
      <param name="gear_ratio">1.0</param>
      <param name="feed_constant">1.0</param>
      <command_interface name="position"/>
      <state_interface name="position">
        <param name="initial_value">$(arg initial_position)</param>
      </state_interface>
    </joint>
  </ros2_control>
</robot>
